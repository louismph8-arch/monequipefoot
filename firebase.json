{
  "hosting": [
    {
      "target": "ojbeziers",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "README.md",
        ".git/**",
        "node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
            { "key": "X-Content-Type-Options", "value": "nosniff" }
          ]
        }
      ]
    }
  ]
}
